# ==========================================
# 1. 의존성 및 패키지 (Unity의 Packages 역할)
# ==========================================
# npm install로 설치되는 외부 라이브러리 폴더입니다. 
# 용량이 수백 MB에 달하므로 절대 Git에 올리면 안 됩니다.
node_modules/
/.pnp
.pnp.js

# ==========================================
# 2. 빌드 결과물 (Unity의 Build 폴더 역할)
# ==========================================
# npm run build를 실행했을 때 생성되는 최종 배포용 폴더입니다.
# 소스 코드가 아니며, GitHub Pages 배포 시 gh-pages 모듈이 알아서 처리하므로 
# 메인 브랜치(main/master)의 Git 추적에서는 제외합니다.
dist/
build/

# build-posts 스크립트가 content/posts에서 자동 생성하는 산출물
# (dev 서버 시작·빌드 시마다 재생성되므로 커밋하지 않음)
public/posts/

# draft 게시물 — 로컬 전용. 저장소에 올라가지 않으며,
# 에디터의 PUBLISH 토글이 content/posts/로 이동시킬 때 비로소 커밋 대상이 된다.
content/drafts/

# ==========================================
# 3. 환경 변수 및 비밀키 (Security)
# ==========================================
# API 키나 보안 코드가 들어가는 파일입니다. GitHub에 공개되면 안 됩니다.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ==========================================
# 4. 로그 및 시스템 임시 파일 (Unity의 Temp/Logs 역할)
# ==========================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
reference-files/

# 구현 문서 — 로컬에만 기록하고 저장소에는 올리지 않는다
# (설계·구현 이력: docs/implementation-plan.md, 그래프 DSL 개발 노트: docs/function-graph-devnotes.md,
#  에이전트 지침: CLAUDE.md)
docs/
CLAUDE.md

# OS 임시 파일
.DS_Store
Thumbs.db

# 에디터 설정 (VS Code 등)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?